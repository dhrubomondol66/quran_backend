# General App Settings
SECRET_KEY=your_secret_key_here
FRONTEND_URL=http://localhost:3000
BACKEND_URL=https://your-app.onrender.com
UPLOAD_DIR=/var/data

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quran_app

# Admin Configuration
ADMIN_SECRET_KEY=your_admin_secret_key_here
ADMIN_INIT_SECRET=your_admin_init_secret_here
ADMIN_EMAILS=hamim.leon@gmail.com
ADMIN_DEFAULT_PASSWORD=quran250

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_TEAM_ID=your_apple_team_id_here

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Payment Configuration (amounts in cents)
PREMIUM_PRICE_MONTHLY=2000
PREMIUM_PRICE_YEARLY=20000

# Email SMTP Settings (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=your_smtp_user_here
SMTP_FROM_NAME=Quran Recitation App

# Email - SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# AI / Voice Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_JSON=            # Paste the entire content of your Firebase JSON key here (for Render)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase/qari-app-ee702-firebase-adminsdk-fbsvc-fa4b701041.json
